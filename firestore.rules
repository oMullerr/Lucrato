rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Dono autenticado: UID conferente + e-mail verificado.
    function isVerifiedOwner(userId) {
      return request.auth != null
             && request.auth.uid == userId
             && request.auth.token.email_verified == true;
    }

    // Cada usuário só LÊ o próprio documento de dados em users/{uid}/db/{doc}.
    // A ESCRITA é feita exclusivamente pelo backend (.NET API via Firebase Admin SDK,
    // que ignora estas regras). O cliente não grava mais diretamente — por isso
    // negamos qualquer write aqui. A validação de formato/limites vive na API.
    match /users/{userId}/db/{docId} {
      allow read:  if isVerifiedOwner(userId);
      allow write: if false;
    }

    // Nega qualquer outro caminho explicitamente.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
